{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=Bulky;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Stripe": {
    "SecretKey": "",
    "PublishableKey": ""
  },
  "Inventory": {
    "WarehouseContainer": "warehouse",
    "WarehouseBlobName": "warehouse_stock.xlsx"
  },
  "AzureOpenAI": {
    "Endpoint": "",
    "DeploymentName": "gpt-4.1-mini",
    "EmbeddingModel": "text-embedding-3-small"
  },
  "AISettings": {
    "MaxTokens": 1000,
    "CacheDurationMinutes": 60,
    "Temperature": 0.7,
    "EnableCaching": true,
    "MaxRetries": 3
  }
}